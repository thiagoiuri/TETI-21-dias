{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile containing personal information and app data.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "nickname": { "type": "string" },
        "birthDate": { "type": "string" },
        "mainObjective": { "type": "string" },
        "isMember": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "startDate": { "type": "string" },
        "logs": { 
          "type": "object", 
          "additionalProperties": { "type": "object" } 
        }
      },
      "required": ["fullName", "nickname", "birthDate", "mainObjective", "isMember", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile and habit tracking data"
    }
  }
}
